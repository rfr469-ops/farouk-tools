    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>AOS.init({ duration: 800, once: true, offset: 100 });</script>

    <script>
        document.getElementById('calculateBtn').addEventListener('click', function() {
            const currency = document.getElementById('currencySelect').value;
            const equity = parseFloat(document.getElementById('equity').value) || 0;
            const costEquity = parseFloat(document.getElementById('costEquity').value) / 100 || 0;
            const debt = parseFloat(document.getElementById('debt').value) || 0;
            const costDebt = parseFloat(document.getElementById('costDebt').value) / 100 || 0;
            const taxRate = parseFloat(document.getElementById('taxRate').value) / 100 || 0;

            if (equity <= 0 && debt <= 0) {
                alert('الرجاء إدخال قيم صحيحة.');
                return;
            }

            const total = equity + debt;
            const weightEquity = equity / total;
            const weightDebt = debt / total;
            const afterTaxCostDebt = costDebt * (1 - taxRate);
            const wacc = (weightEquity * costEquity) + (weightDebt * afterTaxCostDebt);

            // عرض النتائج
            document.getElementById('initialMessage').style.display = 'none';
            document.getElementById('resultsSection').style.display = 'block';

            // بطاقة KPI
            document.getElementById('kpiCards').innerHTML = `
                <div class="result-card">
                    <i class="fas fa-chart-line"></i>
                    <h4>WACC</h4>
                    <div class="value">${(wacc * 100).toFixed(2)}%</div>
                </div>
            `;

            // جدول التفاصيل
            document.getElementById('detailsTable').innerHTML = `
                <table>
                    <tr><th>العنصر</th><th>القيمة (${currency})</th><th>الوزن</th><th>التكلفة قبل الضريبة</th><th>التكلفة بعد الضريبة</th></tr>
                    <tr>
                        <td>حقوق الملكية</td>
                        <td>${currency}${equity.toFixed(0)}</td>
                        <td>${(weightEquity*100).toFixed(2)}%</td>
                        <td>${(costEquity*100).toFixed(2)}%</td>
                        <td>${(costEquity*100).toFixed(2)}%</td>
                    </tr>
                    <tr>
                        <td>الديون</td>
                        <td>${currency}${debt.toFixed(0)}</td>
                        <td>${(weightDebt*100).toFixed(2)}%</td>
                        <td>${(costDebt*100).toFixed(2)}%</td>
                        <td>${(afterTaxCostDebt*100).toFixed(2)}%</td>
                    </tr>
                    <tr style="background:var(--gold-soft); font-weight:900;">
                        <td colspan="4">المتوسط المرجح WACC</td>
                        <td>${(wacc*100).toFixed(2)}%</td>
                    </tr>
                </table>
            `;

            // دوال التصدير
            window.exportExcel = function() {
                const rows = [
                    ['العنصر', 'القيمة', 'الوزن', 'التكلفة قبل الضريبة', 'التكلفة بعد الضريبة'],
                    ['حقوق الملكية', `${currency}${equity.toFixed(0)}`, `${(weightEquity*100).toFixed(2)}%`, `${(costEquity*100).toFixed(2)}%`, `${(costEquity*100).toFixed(2)}%`],
                    ['الديون', `${currency}${debt.toFixed(0)}`, `${(weightDebt*100).toFixed(2)}%`, `${(costDebt*100).toFixed(2)}%`, `${(afterTaxCostDebt*100).toFixed(2)}%`],
                    ['WACC', '', '', '', `${(wacc*100).toFixed(2)}%`]
                ];
                let csvContent = rows.map(row => row.join(',')).join('\n');
                const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                const now = new Date();
                const dateStr = now.toISOString().slice(0,10).replace(/-/g,'');
                link.download = `WACC_${dateStr}.csv`;
                link.href = URL.createObjectURL(blob);
                link.click();
                URL.revokeObjectURL(link.href);
            };

            window.exportWord = function() {
                let htmlContent = `
                    <!DOCTYPE html>
                    <html dir="rtl">
                    <head><meta charset="UTF-8"><title>تقرير WACC</title>
                    <style>
                        body { font-family: 'Tajawal', sans-serif; margin: 2rem; }
                        h1 { color: #b8860b; }
                        table { border-collapse: collapse; width:100%; }
                        th { background: #b8860b33; }
                        td, th { border: 1px solid #ccc; padding: 0.5rem; text-align: center; }
                    </style>
                    </head>
                    <body>
                        <h1>تقرير WACC</h1>
                        <p>تاريخ التقرير: ${new Date().toLocaleDateString('ar-EG')}</p>
