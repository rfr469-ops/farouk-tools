            --gold-light: #d4b15a;
            --gold-soft: rgba(184,134,11,0.1);
            --dark: #0f0f0f;
            --dark-light: #1a1a1a;
            --white: #ffffff;
            --offwhite: #f9f9f9;
            --text: #333;
            --card-bg: #fefcf6;
        }
        body {
            font-family: 'Tajawal', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
            color: var(--text);
            line-height: 1.6;
            overflow-x: hidden;
            position: relative;
        }
        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(184,134,11,0.03) 0px, transparent 20px),
                radial-gradient(circle at 90% 70%, rgba(184,134,11,0.03) 0px, transparent 25px),
                repeating-linear-gradient(45deg, rgba(0,0,0,0.01) 0px, rgba(0,0,0,0.01) 1px, transparent 1px, transparent 10px);
            pointer-events: none; z-index: -1;
        }
        .floating-shape {
            position: absolute;
            width: 300px; height: 300px; border-radius: 50%;
            background: radial-gradient(circle, rgba(184,134,11,0.1) 0%, transparent 70%);
            z-index: 0; pointer-events: none;
        }
        .shape-1 { top: -100px; right: -100px; animation: float 20s infinite ease-in-out; }
        .shape-2 { bottom: -50px; left: -50px; width: 200px; height: 200px; animation: float 15s infinite ease-in-out reverse; }
        @keyframes float {
            0% { transform: translate(0,0) rotate(0deg); }
            33% { transform: translate(30px,-30px) rotate(5deg); }
            66% { transform: translate(-20px,20px) rotate(-5deg); }
            100% { transform: translate(0,0) rotate(0deg); }
        }
        nav {
            background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);
            padding: 1rem 5%; display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid rgba(0,0,0,0.05); position: sticky; top: 0; z-index: 1000;
            box-shadow: 0 2px 20px rgba(0,0,0,0.05);
        }
        .logo { display: flex; align-items: center; gap: 15px; }
        .logo img { height: 50px; width: auto; object-fit: contain; }
        .logo h1 { font-family: 'Alexandria', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--gold); letter-spacing: 1px; }
        nav a { text-decoration: none; color: #444; margin: 0 0.8rem; font-weight: 600; transition: 0.3s; }
        nav a:hover { color: var(--gold); }
        nav a i { margin-left: 5px; }
        .hero-mini {
            background: linear-gradient(135deg, var(--dark) 0%, var(--dark-light) 100%);
            color: white; text-align: center; padding: 3rem 1rem;
            border-bottom: 4px solid var(--gold); position: relative; overflow: hidden;
        }
        .hero-mini::before {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(184,134,11,0.2) 0%, transparent 60%);
            animation: rotate 40s linear infinite;
        }
        @keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        .hero-mini h2 { font-size: 2.5rem; font-weight: 900; color: var(--gold-light); margin-bottom: 0.5rem; position: relative; z-index: 2; }
        .hero-mini p { font-size: 1.2rem; max-width: 700px; margin: 0 auto; opacity: 0.95; position: relative; z-index: 2; }
        .calc-wrapper { max-width: 1200px; margin: 4rem auto; padding: 0 1.5rem; position: relative; z-index: 2; }
        .calc-box {
            background: rgba(255,255,255,0.9); backdrop-filter: blur(15px);
            border: 2px solid var(--gold); border-radius: 40px; padding: 3rem;
            box-shadow: 0 30px 60px rgba(0,0,0,0.2), 0 0 0 1px rgba(184,134,11,0.3) inset;
            position: relative; overflow: hidden;
        }
        .calc-box::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
