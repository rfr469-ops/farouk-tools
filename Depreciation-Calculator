    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>AOS.init({ duration: 800, once: true, offset: 100 });</script>

    <script>
        // إظهار/إخفاء حقل النسبة حسب الطريقة
        document.getElementById('depMethod').addEventListener('change', function() {
            const method = this.value;
            const rateGroup = document.getElementById('rateGroup');
            if (method === 'declining' || method === 'double') {
                rateGroup.style.display = 'block';
            } else {
                rateGroup.style.display = 'none';
            }
        });

        document.getElementById('calculateBtn').addEventListener('click', function() {
            const currency = document.getElementById('currencySelect').value;
            const cost = parseFloat(document.getElementById('assetCost').value) || 0;
            const salvage = parseFloat(document.getElementById('salvageValue').value) || 0;
            const life = parseInt(document.getElementById('usefulLife').value) || 5;
            const method = document.getElementById('depMethod').value;
            const rateInput = parseFloat(document.getElementById('decliningRate').value) || 20;
            const rate = rateInput / 100;

            if (cost <= salvage) {
                alert('تكلفة الأصل يجب أن تكون أكبر من قيمة الإنقاذ.');
                return;
            }

            let depreciationSchedule = [];
            let totalDepreciation = 0;
            let bookValue = cost;
            let annualDep = 0;

            if (method === 'straight') {
                annualDep = (cost - salvage) / life;
                for (let year = 1; year <= life; year++) {
                    bookValue -= annualDep;
                    depreciationSchedule.push({
                        year: year,
                        depreciation: annualDep,
                        accumulated: totalDepreciation + annualDep,
                        bookValue: Math.max(bookValue, salvage)
                    });
                    totalDepreciation += annualDep;
                }
            } else if (method === 'declining') {
                // القسط المتناقص بنسبة ثابتة (لا تراعى قيمة الإنقاذ في الحساب)
                for (let year = 1; year <= life; year++) {
                    annualDep = bookValue * rate;
                    // لا يمكن أن يقل دفتر الأستاذ عن قيمة الإنقاذ
                    if (bookValue - annualDep < salvage) {
                        annualDep = bookValue - salvage;
                    }
                    bookValue -= annualDep;
                    depreciationSchedule.push({
                        year: year,
                        depreciation: annualDep,
                        accumulated: totalDepreciation + annualDep,
                        bookValue: Math.max(bookValue, salvage)
                    });
                    totalDepreciation += annualDep;
                    if (bookValue <= salvage) break;
                }
            } else if (method === 'double') {
                // مضاعف الرصيد: ضعف نسبة القسط الثابت
                const straightRate = 1 / life;
                const doubleRate = straightRate * 2;
                for (let year = 1; year <= life; year++) {
                    annualDep = bookValue * doubleRate;
                    if (bookValue - annualDep < salvage) {
                        annualDep = bookValue - salvage;
                    }
                    bookValue -= annualDep;
                    depreciationSchedule.push({
                        year: year,
                        depreciation: annualDep,
                        accumulated: totalDepreciation + annualDep,
                        bookValue: Math.max(bookValue, salvage)
                    });
                    totalDepreciation += annualDep;
                    if (bookValue <= salvage) break;
                }
            }

            // عرض النتائج
            document.getElementById('initialMessage').style.display = 'none';
            document.getElementById('resultsSection').style.display = 'block';

            // بطاقات KPIs
            document.getElementById('kpiCards').innerHTML = `
                <div class="result-card">
                    <i class="fas fa-dollar-sign"></i>
                    <h4>إجمالي الإهلاك</h4>
                    <div class="value">${currency}${totalDepreciation.toFixed(0)}</div>
                </div>
                <div class="result-card">
                    <i class="fas fa-chart-line"></i>
                    <h4>القيمة الدفترية النهائية</h4>
                    <div class="value">${currency}${(cost - totalDepreciation).toFixed(0)}</div>
                </div>
                <div class="result-card">
                    <i class="fas fa-calendar"></i>
                    <h4>عدد السنوات الفعلية</h4>
                    <div class="value">${depreciationSchedule.length}</div>
                </div>
            `;

            // جدول الإهلاك
            let tableHtml = '<table><thead><tr><th>السنة</th><th>الإهلاك السنوي</th><th>الإهلاك المتراكم</th><th>القيمة الدفترية</th></tr></thead><tbody>';
            depreciationSchedule.forEach(row => {
                tableHtml += `<tr>
                    <td>${row.year}</td>
                    <td>${currency}${row.depreciation.toFixed(0)}</td>
                    <td>${currency}${row.accumulated.toFixed(0)}</td>
                    <td>${currency}${row.bookValue.toFixed(0)}</td>
                </tr>`;
            });
            tableHtml += '</tbody></table>';
            document.getElementById('depTable').innerHTML = tableHtml;

            // دوال التصدير (نفس الأنماط السابقة)
            window.exportExcel = function() {
                const rows = [];
                rows.push(['السنة', 'الإهلاك السنوي', 'الإهلاك المتراكم', 'القيمة الدفترية']);
                depreciationSchedule.forEach(r => {
                    rows.push([r.year, r.depreciation.toFixed(0), r.accumulated.toFixed(0), r.bookValue.toFixed(0)]);
                });
                let csvContent = rows.map(row => row.join(',')).join('\n');
                const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                const now = new Date();
                const dateStr = now.toISOString().slice(0,10).replace(/-/g,'');
                link.download = `إهلاك_${dateStr}.csv`;
                link.href = URL.createObjectURL(blob);
                link.click();
                URL.revokeObjectURL(link.href);
            };

            window.exportWord = function() {
                let htmlContent = `
                    <!DOCTYPE html>
                    <html dir="rtl">
                    <head>
                        <meta charset="UTF-8">
                        <title>تقرير الإهلاك</title>
                        <style>
                            body { font-family: 'Tajawal', sans-serif; margin: 2rem; }
                            h1 { color: #b8860b; }
                            table { border-collapse: collapse; width:100%; }
                            th { background: #b8860b33; }
                            td, th { border: 1px solid #ccc; padding: 0.5rem; text-align: center; }
                        </style>
                    </head>
                    <body>
                        <h1>تقرير الإهلاك</h1>
                        <p>تاريخ التقرير: ${new Date().toLocaleDateString('ar-EG')}</p>
                        <p>تكلفة الأصل: ${currency} ${cost}</p>
                        <p>قيمة الإنقاذ: ${currency} ${salvage}</p>
                        <p>العمر الإنتاجي: ${life} سنة</p>
                        <p>الطريقة: ${method === 'straight' ? 'القسط الثابت' : method === 'declining' ? 'القسط المتناقص' : 'مضاعف الرصيد'}</p>
                        <table>
                            <tr><th>السنة</th><th>الإهلاك السنوي</th><th>الإهلاك المتراكم</th><th>القيمة الدفترية</th></tr>
                `;
                depreciationSchedule.forEach(r => {
                    htmlContent += `<tr><td>${r.year}</td><td>${currency}${r.depreciation.toFixed(0)}</td><td>${currency}${r.accumulated.toFixed(0)}</td><td>${currency}${r.bookValue.toFixed(0)}</td></tr>`;
                });
                htmlContent += `</table></body></html>`;
                const blob = new Blob(['\uFEFF' + htmlContent], { type: 'application/msword' });
                const link = document.createElement('a');
                const now = new Date();
                const dateStr = now.toISOString().slice(0,10).replace(/-/g,'');
                link.download = `تقرير_إهلاك_${dateStr}.doc`;
                link.href = URL.createObjectURL(blob);
                link.click();
                URL.revokeObjectURL(link.href);
            };
        });

        // ربط أزرار التصدير
        document.getElementById('exportExcelBtn').addEventListener('click', function() {
            if (window.exportExcel) window.exportExcel();
        });
        document.getElementById('exportWordBtn').addEventListener('click', function() {
            if (window.exportWord) window.exportWord();
        });
    </script>
</body>
</html>
