            color: var(--text);
            line-height: 1.6;
            overflow-x: hidden;
            position: relative;
        }
        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(184,134,11,0.03) 0px, transparent 20px),
                radial-gradient(circle at 90% 70%, rgba(184,134,11,0.03) 0px, transparent 25px),
                repeating-linear-gradient(45deg, rgba(0,0,0,0.01) 0px, rgba(0,0,0,0.01) 1px, transparent 1px, transparent 10px);
            pointer-events: none; z-index: -1;
        }
        .floating-shape {
            position: absolute;
