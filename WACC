                            <tr><th>العنصر</th><th>القيمة</th><th>الوزن</th><th>التكلفة قبل الضريبة</th><th>التكلفة بعد الضريبة</th></tr>
                            <tr><td>حقوق الملكية</td><td>${currency}${equity.toFixed(0)}</td><td>${(weightEquity*100).toFixed(2)}%</td><td>${(costEquity*100).toFixed(2)}%</td><td>${(costEquity*100).toFixed(2)}%</td></tr>
                            <tr><td>الديون</td><td>${currency}${debt.toFixed(0)}</td><td>${(weightDebt*100).toFixed(2)}%</td><td>${(costDebt*100).toFixed(2)}%</td><td>${(afterTaxCostDebt*100).toFixed(2)}%</td></tr>
                            <tr style="font-weight:900;"><td colspan="4">المتوسط المرجح WACC</td><td>${(wacc*100).toFixed(2)}%</td></tr>
                        </table>
                    </body></html>
                `;
                const blob = new Blob(['\uFEFF' + htmlContent], { type: 'application/msword' });
                const link = document.createElement('a');
                const now = new Date();
                const dateStr = now.toISOString().slice(0,10).replace(/-/g,'');
                link.download = `تقرير_WACC_${dateStr}.doc`;
                link.href = URL.createObjectURL(blob);
                link.click();
                URL.revokeObjectURL(link.href);
            };
        });

        document.getElementById('exportExcelBtn').addEventListener('click', function() {
            if (window.exportExcel) window.exportExcel();
        });
        document.getElementById('exportWordBtn').addEventListener('click', function() {
            if (window.exportWord) window.exportWord();
        });
    </script>
</body>
