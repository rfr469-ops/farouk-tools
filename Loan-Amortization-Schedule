    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>AOS.init({ duration: 800, once: true, offset: 100 });</script>

    <script>
        document.getElementById('calculateBtn').addEventListener('click', function() {
            const currency = document.getElementById('currencySelect').value;
            const principal = parseFloat(document.getElementById('loanAmount').value) || 0;
            const annualRate = parseFloat(document.getElementById('interestRate').value) / 100 || 0;
            const years = parseInt(document.getElementById('loanYears').value) || 10;
            const frequency = parseInt(document.getElementById('paymentFrequency').value); // 12,4,2,1

            if (principal <= 0 || annualRate <= 0 || years <= 0) {
                alert('الرجاء إدخال قيم صحيحة.');
                return;
            }

            const periods = years * frequency;
            const ratePerPeriod = annualRate / frequency;
            // حساب الدفعة الثابتة (معادلة القسط الشهري)
            let payment;
            if (ratePerPeriod === 0) {
                payment = principal / periods;
            } else {
                payment = principal * ratePerPeriod * Math.pow(1 + ratePerPeriod, periods) / (Math.pow(1 + ratePerPeriod, periods) - 1);
            }

            // جدول السداد
            let schedule = [];
            let balance = principal;
            let totalInterest = 0;
            for (let i = 1; i <= periods; i++) {
                const interest = balance * ratePerPeriod;
                const principalPaid = payment - interest;
                balance -= principalPaid;
                totalInterest += interest;
                schedule.push({
                    period: i,
                    payment: payment,
                    interest: interest,
                    principalPaid: principalPaid,
                    balance: balance > 0 ? balance : 0
                });
                if (balance <= 0) break;
            }

            // إجمالي المدفوعات
            const totalPayments = payment * schedule.length;

            // عرض النتائج
            document.getElementById('initialMessage').style.display = 'none';
            document.getElementById('resultsSection').style.display = 'block';

            // بطاقات KPIs
            document.getElementById('kpiCards').innerHTML = `
                <div class="result-card">
                    <i class="fas fa-dollar-sign"></i>
                    <h4>الدفعة الدورية</h4>
                    <div class="value">${currency}${payment.toFixed(2)}</div>
                </div>
                <div class="result-card">
                    <i class="fas fa-chart-line"></i>
                    <h4>إجمالي الفائدة</h4>
                    <div class="value">${currency}${totalInterest.toFixed(2)}</div>
                </div>
                <div class="result-card">
                    <i class="fas fa-coins"></i>
                    <h4>إجمالي المدفوعات</h4>
                    <div class="value">${currency}${totalPayments.toFixed(2)}</div>
                </div>
                <div class="result-card">
                    <i class="fas fa-calendar"></i>
                    <h4>عدد الدفعات</h4>
                    <div class="value">${schedule.length}</div>
                </div>
            `;

            // جدول السداد (أول 12 دفعة أو كل الدفعات إذا كانت أقل)
            let tableHtml = '<table><thead><tr><th>رقم الدفعة</th><th>الدفعة</th><th>الفائدة</th><th>أصل الدين</th><th>الرصيد المتبقي</th></tr></thead><tbody>';
            const rowsToShow = Math.min(schedule.length, 12);
            for (let i = 0; i < rowsToShow; i++) {
                const row = schedule[i];
                tableHtml += `<tr>
                    <td>${row.period}</td>
                    <td>${currency}${row.payment.toFixed(2)}</td>
                    <td>${currency}${row.interest.toFixed(2)}</td>
                    <td>${currency}${row.principalPaid.toFixed(2)}</td>
                    <td>${currency}${row.balance.toFixed(2)}</td>
                </tr>`;
            }
            if (schedule.length > 12) {
                tableHtml += `<tr><td colspan="5">...</td></tr>`;
            }
            tableHtml += '</tbody></table>';
            document.getElementById('amortTable').innerHTML = tableHtml;

            // دوال التصدير
            window.exportExcel = function() {
                const rows = [];
                rows.push(['رقم الدفعة', 'الدفعة', 'الفائدة', 'أصل الدين', 'الرصيد المتبقي']);
                schedule.forEach(r => {
                    rows.push([r.period, r.payment.toFixed(2), r.interest.toFixed(2), r.principalPaid.toFixed(2), r.balance.toFixed(2)]);
                });
                let csvContent = rows.map(row => row.join(',')).join('\n');
                const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                const now = new Date();
                const dateStr = now.toISOString().slice(0,10).replace(/-/g,'');
                link.download = `جدولة_قرض_${dateStr}.csv`;
                link.href = URL.createObjectURL(blob);
                link.click();
                URL.revokeObjectURL(link.href);
            };

            window.exportWord = function() {
                let htmlContent = `
                    <!DOCTYPE html>
                    <html dir="rtl">
                    <head>
                        <meta charset="UTF-8">
                        <title>تقرير جدولة القرض</title>
                        <style>
                            body { font-family: 'Tajawal', sans-serif; margin: 2rem; }
                            h1 { color: #b8860b; }
                            table { border-collapse: collapse; width:100%; }
                            th { background: #b8860b33; }
                            td, th { border: 1px solid #ccc; padding: 0.5rem; text-align: center; }
                        </style>
                    </head>
                    <body>
                        <h1>تقرير جدولة القرض</h1>
                        <p>تاريخ التقرير: ${new Date().toLocaleDateString('ar-EG')}</p>
                        <p>مبلغ القرض: ${currency} ${principal}</p>
                        <p>معدل الفائدة السنوي: ${(annualRate*100).toFixed(2)}%</p>
                        <p>المدة: ${years} سنة</p>
                        <p>تكرار الدفع: ${frequency === 12 ? 'شهري' : frequency === 4 ? 'ربع سنوي' : frequency === 2 ? 'نصف سنوي' : 'سنوي'}</p>
                        <p>الدفعة الدورية: ${currency} ${payment.toFixed(2)}</p>
                        <p>إجمالي الفائدة: ${currency} ${totalInterest.toFixed(2)}</p>
                        <p>إجمالي المدفوعات: ${currency} ${totalPayments.toFixed(2)}</p>
                        <table>
                            <tr><th>رقم الدفعة</th><th>الدفعة</th><th>الفائدة</th><th>أصل الدين</th><th>الرصيد المتبقي</th></tr>
                `;
                schedule.forEach(r => {
                    htmlContent += `<tr><td>${r.period}</td><td>${currency}${r.payment.toFixed(2)}</td><td>${currency}${r.interest.toFixed(2)}</td><td>${currency}${r.principalPaid.toFixed(2)}</td><td>${currency}${r.balance.toFixed(2)}</td></tr>`;
                });
                htmlContent += `</table></body></html>`;
                const blob = new Blob(['\uFEFF' + htmlContent], { type: 'application/msword' });
                const link = document.createElement('a');
                const now = new Date();
                const dateStr = now.toISOString().slice(0,10).replace(/-/g,'');
                link.download = `تقرير_قرض_${dateStr}.doc`;
                link.href = URL.createObjectURL(blob);
                link.click();
                URL.revokeObjectURL(link.href);
            };
        });

        // ربط أزرار التصدير
        document.getElementById('exportExcelBtn').addEventListener('click', function() {
            if (window.exportExcel) window.exportExcel();
        });
        document.getElementById('exportWordBtn').addEventListener('click', function() {
            if (window.exportWord) window.exportWord();
        });
    </script>
</body>
</html>
