            .featured-badge i { font-size: 1.5rem; }
            .featured-badge span { font-size: 0.7rem; }
            .footer-row { flex-direction: column; text-align: center; }
            .footer-social { justify-content: center; }
            .footer-payment { justify-content: center; }
        }
    </style>
