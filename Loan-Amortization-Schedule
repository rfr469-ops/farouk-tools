            nav > div:last-child { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; }
            nav a { margin: 0; font-size: 0.9rem; padding: 4px 8px; white-space: nowrap; }
            .hero-mini h2 { font-size: 2rem; }
            .hero-mini p { font-size: 1rem; }
            .calc-box { padding: 2rem 1.5rem; }
            .form-row { flex-direction: column; gap: 0; }
